#
# PocketDev Linux Kernel Configuration for ARM64
# Based on Apple Containerization's kernel config
# Optimized for fast boot (<500ms) and minimal footprint
# Target: Linux 6.18.x
#

# Architecture
CONFIG_ARM64=y
CONFIG_64BIT=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_ARM64_PA_BITS_48=y
CONFIG_ARM64_4K_PAGES=y

# General
CONFIG_LOCALVERSION="-pocketdev"
CONFIG_DEFAULT_HOSTNAME="pocketdev"
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_HZ_250=y
CONFIG_HZ=250

# CRITICAL: Monolithic kernel (no modules = faster boot)
# CONFIG_MODULES is not set

# Preemption (server-optimized for throughput)
CONFIG_PREEMPT_NONE=y

# SMP
CONFIG_SMP=y
CONFIG_NR_CPUS=8

# Memory
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_KSM=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_LZO=y
CONFIG_MEMORY_HOTPLUG=y

# Virtio (essential for VM communication)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_VSOCK=y
CONFIG_VHOST_VSOCK=y

# Block devices
CONFIG_BLK_DEV=y
CONFIG_BLOCK=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_OVERLAY_FS=y
CONFIG_FUSE_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_SQUASHFS=y

# 9P filesystem (for shared directories)
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y

# Cgroups v2 (container resource management)
CONFIG_CGROUPS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y

# Namespaces (container isolation)
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_FILTER=y
CONFIG_BRIDGE=y
CONFIG_VLAN_8021Q=y
CONFIG_VETH=y
CONFIG_TUN=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# Netlink (required for vminitd networking)
CONFIG_NETLINK_DIAG=y

# Security
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY=y

# Crypto
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_AES=y

# PL011 UART (declared in FDT as /pl011@9000000)
CONFIG_SERIAL_CORE=y
CONFIG_SERIAL_CORE_CONSOLE=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# GICv3 interrupt controller (declared in FDT as /intc@8000000)
CONFIG_ARM_GIC_V3=y
CONFIG_IRQ_DOMAIN=y
CONFIG_IRQCHIP=y

# ARM generic timer (declared in FDT as /timer)
CONFIG_ARM_ARCH_TIMER=y

# TTY / Console
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_HVC_DRIVER=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_PRINTK=y

# Epoll (required for vminitd ProcessSupervisor)
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y

# Splice (zero-copy I/O for vsock proxy)
CONFIG_SPLICE=y

# POSIX timers and clocks
CONFIG_POSIX_TIMERS=y

# Disable unnecessary subsystems for fast boot
# CONFIG_SOUND is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_BLUETOOTH is not set
# CONFIG_INPUT_MOUSEDEV is not set
# CONFIG_INPUT_JOYDEV is not set
# CONFIG_SERIO is not set
# CONFIG_VGA_CONSOLE is not set
# CONFIG_FRAMEBUFFER_CONSOLE is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_SUSPEND is not set
# CONFIG_HIBERNATION is not set
# CONFIG_ACPI is not set
# CONFIG_SCSI is not set
# CONFIG_ATA is not set
# CONFIG_MD is not set
# CONFIG_INFINIBAND is not set
# CONFIG_ISDN is not set
# CONFIG_NFC is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_HWMON is not set
# CONFIG_THERMAL is not set
# CONFIG_WATCHDOG is not set
# CONFIG_REGULATOR is not set
# CONFIG_PWM is not set
# CONFIG_IIO is not set
# CONFIG_STAGING is not set
